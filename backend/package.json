{
  "name": "volt-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "node --watch --loader ts-node/esm src/server.ts",
    "build": "tsc",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy"
  },
  "dependencies": {
