# Frontend (Next.js)
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_CURRENCY_SYMBOL=₸

# Валюта: символ для отображения цен (по умолчанию ₽ в Docker)
# Для Docker: создайте .env и задайте NEXT_PUBLIC_CURRENCY_SYMBOL=₽
# Важно: NEXT_PUBLIC_* встраивается при build, не в runtime

# Backend (Express)
# BACKEND_PORT=4000
# JWT_SECRET=change-me-in-production
# FRONTEND_URL=http://localhost

# Database (optional, when enabling PostgreSQL in docker-compose)
# DB_PASSWORD=volt
# DB_USER=volt
# DB_NAME=volt
# DB_HOST_PORT=5433
