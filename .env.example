# Docker compose / Backend secrets
POSTGRES_DB=volt_db
POSTGRES_USER=volt_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET
JWT_EXPIRES_IN=7d
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
REDIS_URL=redis://redis:6379
FRONTEND_URL=http://localhost
APP_URL=https://voltstore.app
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
RESEND_FROM=VOLT Store <noreply@voltstore.app>
RESEND_REPLY_TO=support@voltstore.app
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Frontend (Next.js)
NEXT_PUBLIC_CURRENCY_SYMBOL=$
# Optional: uncomment if frontend calls external API
# NEXT_PUBLIC_API_URL=http://localhost
